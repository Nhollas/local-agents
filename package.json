{
	"name": "local-agents",
	"version": "1.0.0",
	"description": "Local autonomous agents powered by Claude Agent SDK",
	"type": "module",
	"scripts": {
		"prepare": "husky",
		"start": "node server.ts",
		"dev": "concurrently -n orchestrator,dashboard -c blue,magenta \"node --watch server.ts\" \"vite --config dashboard/vite.config.ts\"",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"test": "vitest run",
		"test:unit": "vitest run --project unit",
		"test:integration": "vitest run --project integration",
		"test:dashboard": "vitest run --project dashboard",
		"typecheck": "tsc --noEmit",
		"knip": "knip"
	},
	"lint-staged": {
		"*.{ts,tsx,json,mjs}": "biome check --write --no-errors-on-unmatched"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"engines": {
		"node": ">=22.6.0"
	},
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "^0.2.77",
		"@hono/node-server": "^1.19.11",
		"@tanstack/react-query": "^5.91.2",
		"better-sqlite3": "^12.8.0",
		"dotenv": "^17.3.1",
		"drizzle-orm": "^0.45.1",
		"hono": "^4.12.8",
		"pino": "^10.3.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"yaml": "^2.8.3",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@commitlint/cli": "^20.4.4",
		"@commitlint/config-conventional": "^20.4.4",
		"@tailwindcss/vite": "^4.2.2",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/browser-playwright": "^4.1.0",
		"concurrently": "^9.2.1",
		"husky": "^9.1.7",
		"knip": "^6.0.6",
		"lint-staged": "^16.3.3",
		"msw": "^2.12.13",
		"pino-pretty": "^13.1.3",
		"playwright": "^1.58.2",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vite": "^8.0.1",
		"vitest": "^4.1.0",
		"vitest-browser-react": "^2.1.0"
	}
}
